<?xml version="1.0" encoding="UTF-8" standalone="yes"?><w:document xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main"><w:body><w:p><w:r><w:rPr><w:b/></w:rPr><w:t xml:space="preserve">Especificación técnica breve del MVP - Incident Intake Agent</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/></w:rPr><w:t xml:space="preserve">1. Objetivo técnico</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Definir la arquitectura mínima necesaria para recibir correos de incidencias, analizarlos con IA y crear un borrador de incidencia en OneData Property Management dentro de Business Central.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/></w:rPr><w:t xml:space="preserve">2. Alcance técnico del MVP</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">El MVP cubre únicamente el flujo de entrada y preparación de la incidencia. No incluye cierre automático, respuesta automática al cliente ni notificación automática al seguro.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Incluye:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Lectura del correo desde un buzón compartido</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Creación de un registro buffer en Business Central</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Llamada a un servicio IA externo</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Recepción de un JSON estructurado</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Aplicación de sugerencias al buffer</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Creación de borrador en Incident Assets Real Estate</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Revisión humana desde Business Central</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/></w:rPr><w:t xml:space="preserve">3. Arquitectura propuesta</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">La arquitectura recomendada para el MVP es la siguiente:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">1. Buzón Office 365 compartido (por ejemplo office@forne.family)</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2. Proceso de recogida de correos</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">3. Servicio de IA accesible mediante API REST</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">4. Business Central como sistema de revisión y alta final</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Capas:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Capa de entrada: Office 365</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Capa de integración: Power Automate o Microsoft Graph</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Capa de IA: OpenAI, Azure OpenAI o API propia</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Capa de negocio: AI Incident Intake Buffer + AI Incident Intake Mgt.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Capa destino: Incident Assets Real Estate</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/></w:rPr><w:t xml:space="preserve">4. Origen del correo</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">La cuenta actual indicada es office@forne.family.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Opciones técnicas de lectura:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Opción A: Power Automate</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  Ventajas: rápida implantación, baja barrera técnica, muy integrada con Microsoft 365</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  Inconvenientes: menos control técnico fino, posible dependencia funcional del flujo</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Opción B: Microsoft Graph</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  Ventajas: mayor control, más flexible y más cercano a una arquitectura de producto</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  Inconvenientes: requiere más desarrollo técnico y configuración de autenticación</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Recomendación MVP:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Si se quiere arrancar rápido: Power Automate</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Si se quiere una arquitectura más producto desde el inicio: Microsoft Graph</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/></w:rPr><w:t xml:space="preserve">5. Objetos Business Central implicados</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Objetos ya preparados o iniciados en la solución:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- AI Incident Intake Buffer</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- AI Incident Intake Buffers</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- AI Incident Intake Mgt.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Incident Assets Real Estate</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- RE Incident Card</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- RE Incidents List</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Responsabilidades:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- AI Incident Intake Buffer: almacenar el correo y las sugerencias IA</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- AI Incident Intake Mgt.: registrar entrada, aplicar sugerencias y crear el borrador</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Incident Assets Real Estate: almacenar la incidencia final o borrador</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/></w:rPr><w:t xml:space="preserve">6. Request JSON recomendado al servicio IA</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">El cuerpo de entrada debería ser estable y simple. Propuesta inicial:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">{</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  &quot;subject&quot;: &quot;Fuga de agua en cocina&quot;,</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  &quot;fromEmail&quot;: &quot;cliente@correo.com&quot;,</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  &quot;fromName&quot;: &quot;María Pérez&quot;,</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  &quot;body&quot;: &quot;Buenos días, hay una fuga de agua en la cocina desde ayer...&quot;,</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  &quot;receivedAt&quot;: &quot;2026-04-10T09:30:00Z&quot;,</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  &quot;attachments&quot;: [&quot;foto1.jpg&quot;, &quot;parte.pdf&quot;]</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">}</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Campos mínimos:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- subject</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- fromEmail</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- fromName</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- body</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- receivedAt</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- attachments</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/></w:rPr><w:t xml:space="preserve">7. Response JSON recomendado del servicio IA</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Respuesta estructurada propuesta:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">{</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  &quot;summary&quot;: &quot;Incidencia por fuga de agua en cocina&quot;,</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  &quot;confidence&quot;: 0.91,</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  &quot;title&quot;: &quot;Fuga de agua en cocina&quot;,</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  &quot;description&quot;: &quot;El remitente informa de una fuga bajo el fregadero desde el día anterior.&quot;,</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  &quot;realEstateNo&quot;: &quot;RE0001&quot;,</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  &quot;contractNo&quot;: &quot;LC0003&quot;,</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  &quot;contactNo&quot;: &quot;CT0008&quot;,</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  &quot;insurancePolicyNo&quot;: &quot;SEG0004&quot;,</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  &quot;incidentDate&quot;: &quot;2026-04-10&quot;,</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  &quot;priority&quot;: &quot;High&quot;,</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  &quot;caseType&quot;: &quot;Problem&quot;,</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  &quot;notifyInsurance&quot;: true,</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  &quot;insuranceReason&quot;: &quot;Daño por agua&quot;</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">}</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Campos mínimos recomendados:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- summary</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- confidence</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- title</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- description</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- realEstateNo</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- contractNo</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- contactNo</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- priority</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- caseType</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- notifyInsurance</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/></w:rPr><w:t xml:space="preserve">8. Mapa de campos entre buffer e incidencia</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Propuesta de mapeo:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Suggested Title -&gt; Incident.Title</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Suggested Description -&gt; Incident.Description</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Suggested Real Estate No. -&gt; Incident.Fixed Real Estate No.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Suggested Contract No. -&gt; Incident.Contract No.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Suggested Contact No. -&gt; Incident.Contact No</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Suggested Insurance Policy No. -&gt; Incident.Insurance Policy No.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- AI Notify Insurance -&gt; Incident.Notify Insurance</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- AI Priority -&gt; Incident.Priority</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- AI Case Type -&gt; Incident.Case Type</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- AI Summary -&gt; Incident.REF Description</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Suggested Incident Date -&gt; Incident.Incident Date</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/></w:rPr><w:t xml:space="preserve">9. Reglas de confianza recomendadas</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Propuesta inicial para el MVP:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- confidence &gt;= 0.85</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  Estado: ReadyToCreate</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  Acción: crear borrador con alta probabilidad de acierto</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- confidence entre 0.60 y 0.84</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  Estado: Analyzed</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  Acción: revisión humana antes de crear</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- confidence &lt; 0.60</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  Estado: Error o revisión pendiente</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">  Acción: no automatizar creación</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/></w:rPr><w:t xml:space="preserve">10. Tratamiento de adjuntos</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">En el MVP, los adjuntos pueden tratarse en dos niveles:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Nivel 1: solo enviar nombres de archivo al modelo</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Nivel 2: enviar contenido extraído si el proveedor lo permite y si se valida seguridad</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Recomendación MVP:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- empezar solo con metadata de adjuntos</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- no enviar binarios al modelo hasta validar coste, privacidad y utilidad real</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/></w:rPr><w:t xml:space="preserve">11. Errores y trazabilidad</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">El sistema debe guardar al menos:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- fecha de recepción</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- remitente</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- asunto</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- original message id</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- resumen IA</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- confianza</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- log de procesamiento</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- vínculo a la incidencia creada</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">En caso de error:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- marcar el buffer en estado Error</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- guardar el mensaje técnico en Processing Log</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- no perder nunca el correo original en el buffer</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/></w:rPr><w:t xml:space="preserve">12. Seguridad</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Se deben contemplar estas medidas mínimas:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- no hardcodear claves API en código AL</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- aislar la autenticación en configuración segura o servicio intermedio</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- revisar tratamiento de datos personales del correo</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- controlar qué usuarios pueden revisar o crear incidencias desde el buffer</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/></w:rPr><w:t xml:space="preserve">13. Recomendación técnica final</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Para el MVP, la recomendación es:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Office 365 como origen del correo</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Power Automate como mecanismo de recogida si se quiere velocidad de implantación</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- OpenAI o Azure OpenAI como servicio IA</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">- Business Central como buffer, revisión y creación de borradores</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Si el objetivo es un producto más robusto a medio plazo, Microsoft Graph es mejor base que Power Automate.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve"></w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/></w:rPr><w:t xml:space="preserve">14. Siguiente paso técnico inmediato</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">El siguiente paso técnico debería ser cerrar estas cuatro decisiones:</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">1. Elegir Power Automate o Microsoft Graph</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2. Definir el endpoint real del modelo IA</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">3. Confirmar el request/response JSON</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">4. Decidir el umbral de confianza para crear borradores automáticamente</w:t></w:r></w:p><w:sectPr><w:pgSz w:w="11906" w:h="16838"/><w:pgMar w:top="1440" w:right="1440" w:bottom="1440" w:left="1440" w:header="708" w:footer="708" w:gutter="0"/></w:sectPr></w:body></w:document>
